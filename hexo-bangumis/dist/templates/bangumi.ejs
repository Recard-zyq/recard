<% if (quote) { %>
<blockquote>
    <p><%- quote; %></p>
</blockquote>
<% } %>
<style>
    <%- include('index.css') %>
</style>
<div class="bangumi-tabs">
    <a class="bangumi-tab" id="bangumi-tab1" href="javascript:;" rel="external" target="_self" onclick="return false">
    <%= __('wantWatch') %>
    (<%= wantWatch.length %>)</a>
    <a class="bangumi-tab" id="bangumi-tab2" href="javascript:;" rel="external" target="_self" onclick="return false">
        <%= __('watching') %>
        (<%= watching.length %>)</a>
    <a class="bangumi-tab" id="bangumi-tab3" href="javascript:;" rel="external" target="_self" onclick="return false">
        <%= __('watched') %>
        (<%= watched.length %>)</a>
    <a class="bangumi-tab" id="bangumi-tab4" href="javascript:;" rel="external" target="_self" onclick="return false">
        搁置
        (<%= onHold.length %>)</a>
    <a class="bangumi-tab" id="bangumi-tab5" href="javascript:;" rel="external" target="_self" onclick="return false">
        抛弃
        (<%= dropped.length %>)</a>
</div>
<div>
    <div id="bangumi-item1">
        <% wantWatch.forEach(function(item) { %>
        <%- include('bgm-template.ejs', { item, loading, color_meta }) %>
        <% }); %>
        <%- include('pagination.ejs', {__: __}) %>
    </div>
    <div id="bangumi-item2">
        <% watching.forEach(function(item) { %>
        <%- include('bgm-template.ejs', { item, loading, color_meta }) %>
        <% }); %>
        <%- include('pagination.ejs', {__: __}) %>
    </div>
    <div id="bangumi-item3">
        <% watched.forEach(function(item) { %>
        <%- include('bgm-template.ejs', { item, loading, color_meta }) %>
        <% }); %>
        <%- include('pagination.ejs', {__: __}) %>
    </div>
    <div id="bangumi-item4">
        <% onHold.forEach(function(item) { %>
        <%- include('bgm-template.ejs', { item, loading, color_meta }) %>
        <% }); %>
        <%- include('pagination.ejs', {__: __}) %>
    </div>
    <div id="bangumi-item5">
        <% dropped.forEach(function(item) { %>
        <%- include('bgm-template.ejs', { item, loading, color_meta }) %>
        <% }); %>
        <%- include('pagination.ejs', {__: __}) %>
    </div>
</div>
<script>
    <%- include('index.js') %>
    document.getElementsByClassName('bangumi-tab')[<%- show %>].click();
    <%- include('pagination.js', {__: __}) %>
</script>
